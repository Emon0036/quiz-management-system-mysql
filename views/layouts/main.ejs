<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#0e4b78">
    <title><%= title ? `${title} | ${appName}` : appName %></title>
    <script>
      (() => {
        try {
          const storedTheme = localStorage.getItem('quizAppTheme');
          const theme = storedTheme === 'dark' ? 'dark' : 'light';
          document.documentElement.classList.toggle('theme-dark', theme === 'dark');
          document.documentElement.dataset.theme = theme;
          document.documentElement.style.colorScheme = theme === 'dark' ? 'dark' : 'light';
          const themeMeta = document.querySelector('meta[name="theme-color"]');
          if (themeMeta) {
            themeMeta.setAttribute('content', theme === 'dark' ? '#1f2d33' : '#0e4b78');
          }
        } catch {}
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: {
                50: '#eff6ff',
                100: '#dbeafe',
                200: '#bfdbfe',
                300: '#93c5fd',
                400: '#60a5fa',
                500: '#3b82f6',
                600: '#2563eb',
                700: '#1d4ed8',
                800: '#1e40af',
                900: '#1e3a8a',
                950: '#172554',
              },
              accent: {
                50: '#f0fdfa',
                100: '#ccfbf1',
                200: '#99f6e4',
                300: '#5eead4',
                400: '#2dd4bf',
                500: '#14b8a6',
                600: '#0d9488',
                700: '#0f766e',
                800: '#115e59',
                900: '#134e4a',
                950: '#042f2e',
              }
            },
            fontFamily: {
              sans: ['Roboto', 'system-ui', '-apple-system', 'sans-serif'],
            },
            animation: {
              'fade-in': 'fadeIn 0.5s ease-in-out',
              'slide-up': 'slideUp 0.3s ease-out',
              'bounce-subtle': 'bounceSubtle 2s infinite',
            },
            keyframes: {
              fadeIn: {
                '0%': { opacity: '0' },
                '100%': { opacity: '1' },
              },
              slideUp: {
                '0%': { transform: 'translateY(10px)', opacity: '0' },
                '100%': { transform: 'translateY(0)', opacity: '1' },
              },
              bounceSubtle: {
                '0%, 100%': { transform: 'translateY(0)' },
                '50%': { transform: 'translateY(-5px)' },
              },
            },
          },
        },
      }
    </script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
  </head>
  <body
    class="app-body <%= currentUser ? 'is-signed-in' : 'is-public' %> <%= typeof pageClass !== 'undefined' ? pageClass : '' %>"
    data-current-tab-id="<%= currentTabId || '' %>"
  >
    <div class="site-shell">
      <div class="site-backdrop" aria-hidden="true"></div>
      <% if (typeof hideSiteChrome !== 'undefined' && hideSiteChrome) { %>
        <button type="button" class="theme-toggle theme-toggle--floating" data-theme-toggle aria-label="Toggle dark mode">
          <i class="fas fa-moon theme-toggle__icon" data-theme-icon></i>
          <span class="theme-toggle__label" data-theme-label>Dark mode</span>
        </button>
      <% } %>
      <% if (!(typeof hideSiteChrome !== 'undefined' && hideSiteChrome)) { %>
        <%- include('../partials/navbar') %>
      <% } %>
      <main class="site-main <%= typeof hideSiteChrome !== 'undefined' && hideSiteChrome ? 'site-main--auth' : '' %>">
        <%- include('../partials/flash') %>
        <%- body %>
      </main>
      <% if (!(typeof hideSiteChrome !== 'undefined' && hideSiteChrome)) { %>
        <%- include('../partials/footer') %>
      <% } %>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <script src="/js/app.js"></script>
  </body>
</html>
