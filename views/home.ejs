<% layout('layouts/main') %>
<%
  const quizzes = Array.isArray(featuredQuizzes) ? featuredQuizzes : [];
  const previewQuiz = quizzes[0] || null;
  const examTypeLabels = {
    quiz: 'Mixed quiz',
    'true-false': 'True/False',
    'short-answer': 'Short answer',
    'coding-test': 'Coding exam',
  };
  const roleCards = [
    {
      icon: 'fa-user-graduate',
      title: 'Students',
      copy: 'Find exams, submit attempts, review feedback, and track progress from one workspace.',
      action: 'Join as student',
      href: '/auth/register',
    },
    {
      icon: 'fa-chalkboard-user',
      title: 'Teachers',
      copy: 'Create exams, upload student sheets, publish quizzes, and review written or coding answers.',
      action: 'Request access',
      href: '/auth/register?role=teacher',
    },
    {
      icon: 'fa-user-shield',
      title: 'Admins',
      copy: 'Approve teachers, manage users, and keep the platform organized for the institution.',
      action: 'Admin setup',
      href: '/admin/setup',
    },
  ];
  const workflowSteps = [
    ['Create', 'Teachers prepare exams and attach student rosters when needed.'],
    ['Attempt', 'Students enroll, verify their ID, and submit within the allowed attempts.'],
    ['Review', 'Auto scores publish quickly, while manual answers wait for teacher review.'],
  ];
%>

<section class="landing-page">
  <section class="landing-hero" aria-labelledby="landing-title">
    <div class="landing-hero__scene" aria-hidden="true">
      <div class="landing-screen">
        <div class="landing-screen__topbar">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="landing-screen__body">
          <div class="landing-screen__sidebar">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="landing-screen__content">
            <div class="landing-screen__header">
              <strong><%= previewQuiz ? previewQuiz.title : 'Database Management Quiz' %></strong>
              <small><%= previewQuiz ? `${previewQuiz.totalMarks || 0} marks` : '45 marks' %></small>
            </div>
            <div class="landing-screen__chart">
              <span style="height: 56%"></span>
              <span style="height: 78%"></span>
              <span style="height: 42%"></span>
              <span style="height: 88%"></span>
              <span style="height: 64%"></span>
            </div>
            <div class="landing-screen__rows">
              <span></span>
              <span></span>
              <span></span>
            </div>
          </div>
        </div>
      </div>
      <div class="landing-floating landing-floating--score">
        <i class="fas fa-chart-line"></i>
        <span>Live progress</span>
        <strong>92%</strong>
      </div>
      <div class="landing-floating landing-floating--review">
        <i class="fas fa-clipboard-check"></i>
        <span>Pending review</span>
        <strong>12</strong>
      </div>
    </div>

    <div class="page-container landing-hero__copy">
      <span class="landing-kicker"><i class="fas fa-layer-group"></i> Online quiz management system</span>
      <h1 id="landing-title"><%= appName %></h1>
      <p>
        A clean workspace where teachers create exams, students complete attempts, and admins manage access without switching tools.
      </p>
      <div class="landing-actions">
        <a href="/auth/register" class="btn btn-primary">
          <i class="fas fa-user-plus"></i>
          Create account
        </a>
        <a href="/features" class="btn btn-secondary">
          <i class="fas fa-list-check"></i>
          View features
        </a>
      </div>
      <div class="landing-hero__facts" aria-label="Platform highlights">
        <span><strong>3</strong> roles</span>
        <span><strong>4</strong> exam types</span>
        <span><strong><%= quizzes.length %></strong> published exam<%= quizzes.length === 1 ? '' : 's' %></span>
      </div>
    </div>
  </section>

  <section class="page-container landing-section landing-section--pull">
    <div class="landing-section__intro">
      <span class="landing-kicker">Workspaces</span>
      <h2>Everything is organized by role.</h2>
      <p>Each user sees the tools they need, so the system stays simple for daily class work.</p>
    </div>

    <div class="landing-role-grid">
      <% roleCards.forEach((role) => { %>
        <article class="landing-role-card">
          <div class="landing-role-card__icon"><i class="fas <%= role.icon %>"></i></div>
          <h3><%= role.title %></h3>
          <p><%= role.copy %></p>
          <a href="<%= role.href %>">
            <span><%= role.action %></span>
            <i class="fas fa-arrow-right"></i>
          </a>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="landing-band">
    <div class="page-container landing-flow">
      <div class="landing-section__intro">
        <span class="landing-kicker">Flow</span>
        <h2>From exam setup to final marks.</h2>
      </div>

      <div class="landing-flow__steps">
        <% workflowSteps.forEach((step, index) => { %>
          <article class="landing-flow-step">
            <span><%= index + 1 %></span>
            <h3><%= step[0] %></h3>
            <p><%= step[1] %></p>
          </article>
        <% }) %>
      </div>
    </div>
  </section>

  <section class="page-container landing-section">
    <div class="landing-section__intro landing-section__intro--split">
      <div>
        <span class="landing-kicker">Published exams</span>
        <h2>Students can start from a clear exam list.</h2>
      </div>
      <p>
        The homepage can show real published quizzes, including teacher, duration, difficulty, marks, and exam type.
      </p>
    </div>

    <% if (quizzes.length) { %>
      <div class="landing-quiz-grid">
        <% quizzes.slice(0, 3).forEach((quiz) => { %>
          <article class="landing-quiz-card">
            <% if (quiz.thumbnailUrl) { %>
              <img src="<%= quiz.thumbnailUrl %>" alt="<%= quiz.title %> thumbnail" loading="lazy">
            <% } else { %>
              <div class="landing-quiz-card__placeholder" aria-hidden="true">
                <i class="fas fa-file-lines"></i>
              </div>
            <% } %>
            <div class="landing-quiz-card__body">
              <span><%= examTypeLabels[quiz.examType || 'quiz'] || 'Exam' %></span>
              <h3><%= quiz.title %></h3>
              <p><%= quiz.description || 'No description added yet.' %></p>
              <div class="landing-quiz-card__meta">
                <small><i class="fas fa-clock"></i> <%= quiz.duration || 0 %> min</small>
                <small><i class="fas fa-layer-group"></i> <%= quiz.totalMarks || 0 %> marks</small>
                <small><i class="fas fa-user-tie"></i> <%= quiz.createdBy?.name || 'Teacher' %></small>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="landing-empty-preview">
        <i class="fas fa-book-open"></i>
        <div>
          <h3>No published exams yet.</h3>
          <p>Create and publish a quiz as a teacher, then it will appear here for students.</p>
        </div>
      </div>
    <% } %>
  </section>

  <section class="page-container landing-section">
    <div class="landing-panel">
      <div>
        <span class="landing-kicker">Built-in coverage</span>
        <h2>Quiz, roster, review, and ranking tools in one place.</h2>
        <p>
          The landing page now matches what the system actually does, so new users understand where to go next.
        </p>
      </div>
      <div class="landing-check-grid">
        <span><i class="fas fa-check"></i> Student enrollment</span>
        <span><i class="fas fa-check"></i> Teacher approval</span>
        <span><i class="fas fa-check"></i> Roster upload</span>
        <span><i class="fas fa-check"></i> Manual review</span>
        <span><i class="fas fa-check"></i> Leaderboards</span>
        <span><i class="fas fa-check"></i> Coding problems</span>
      </div>
    </div>
  </section>

  <section class="landing-cta">
    <div class="page-container landing-cta__inner">
      <div>
        <span class="landing-kicker">Get started</span>
        <h2>Ready to use <%= appName %>?</h2>
        <p>
          Create a student account now, or register as a teacher and wait for admin approval.
        </p>
      </div>
      <div class="landing-actions">
        <a href="/auth/register" class="btn btn-primary">
          <i class="fas fa-user-plus"></i>
          Register
        </a>
        <a href="/auth/login" class="btn btn-secondary">
          <i class="fas fa-right-to-bracket"></i>
          Sign in
        </a>
      </div>
    </div>
  </section>
</section>
