<% layout('layouts/main') %>

<section class="page-shell">
  <div class="page-container page-stack">
    <div class="page-heading">
      <div>
        <span class="eyebrow">Teacher Profile</span>
        <h1>Edit profile</h1>
        <p>Update the information shown to admins and enrolled students.</p>
      </div>
      <div class="toolbar">
        <a href="/teacher/profile" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </div>

    <form class="form-panel profile-form" action="/teacher/profile?_method=PATCH" method="POST">
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label" for="name">Full name</label>
          <input id="name" class="form-control" name="name" value="<%= currentUser.name || '' %>" required>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="designation">Designation</label>
          <input id="designation" class="form-control" name="designation" value="<%= currentUser.designation || '' %>" required>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="institution">Institution</label>
          <input id="institution" class="form-control" name="institution" value="<%= currentUser.institution || '' %>" required>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="department">Department</label>
          <input id="department" class="form-control" name="department" value="<%= currentUser.department || '' %>" required>
        </div>
        <div class="col-md-4">
          <label class="form-label" for="phone">Phone</label>
          <input id="phone" class="form-control" name="phone" value="<%= currentUser.phone || '' %>">
        </div>
        <div class="col-md-4">
          <label class="form-label" for="officeLocation">Office</label>
          <input id="officeLocation" class="form-control" name="officeLocation" value="<%= currentUser.officeLocation || '' %>">
        </div>
        <div class="col-md-4">
          <label class="form-label" for="officeHours">Office Hours</label>
          <input id="officeHours" class="form-control" name="officeHours" value="<%= currentUser.officeHours || '' %>">
        </div>
        <div class="col-12">
          <label class="form-label" for="expertise">Expertise</label>
          <textarea id="expertise" class="form-control" name="expertise" rows="3"><%= currentUser.expertise || '' %></textarea>
        </div>
        <div class="col-12">
          <label class="form-label" for="bio">Bio</label>
          <textarea id="bio" class="form-control" name="bio" rows="4"><%= currentUser.bio || '' %></textarea>
        </div>
      </div>

      <div class="toolbar mt-4">
        <button class="btn btn-primary" type="submit">
          <i class="fas fa-floppy-disk"></i>
          Save Profile
        </button>
      </div>
    </form>
  </div>
</section>
