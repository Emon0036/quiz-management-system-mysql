<% layout('layouts/main') %>
<%
  const quiz = attempt.quiz || {};
  const student = attempt.student || {};
%>
<section class="page-shell">
  <div class="page-container page-stack">
    <div class="page-heading">
      <div>
        <span class="eyebrow">Manual Review</span>
        <p class="text-muted mb-1">Attempt <%= attempt.attemptNumber || 1 %></p>
        <h1><%= student.name || 'Deleted student' %> &middot; <%= quiz.title || 'Deleted exam' %></h1>
        <p><%= student.email || 'Account unavailable' %> &middot; Review written or coding answers and assign final marks.</p>
      </div>
    </div>

    <form action="/teacher/attempts/<%= attempt._id %>/review?_method=PATCH" method="POST" class="form-panel">
      <% attempt.answers.forEach((answer, index) => { %>
        <% const question = answer.question || {}; %>
        <% const questionType = question.type || 'unknown'; %>
        <% const questionMarks = Number(question.marks || answer.marksObtained || 0); %>
        <% const isManualQuestion = ['short-answer', 'coding'].includes(questionType); %>
        <% const referenceAnswer = answer.teacherCorrectAnswer || question.correctAnswer || ''; %>
        <div class="review-item bg-white rounded-3 p-4 mb-4 shadow-sm">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <h2 class="h5 mb-1"><%= index + 1 %>. <%= question.questionText || 'Deleted question' %></h2>
              <p class="text-muted mb-0">Marks: <strong><%= questionMarks %></strong></p>
            </div>
            <% if (!answer.needsManualReview) { %>
              <span class="badge <%= answer.isCorrect ? 'text-bg-success' : 'text-bg-danger' %>"><%= answer.marksObtained %>/<%= questionMarks %></span>
            <% } %>
          </div>

          <% if (questionType === 'coding') { %>
            <div class="mb-3">
              <p class="text-muted mb-2"><strong>Student code:</strong></p>
              <pre class="code-block"><code><%= answer.answer || '(No code submitted)' %></code></pre>
            </div>
          <% } else { %>
            <div class="mb-3">
              <p class="text-muted mb-2"><strong>Student answer:</strong></p>
              <div class="p-3 bg-gray-50 rounded"><%= answer.answer || '(Not answered)' %></div>
            </div>
          <% } %>

          <% if (answer.needsManualReview) { %>
            <div class="mb-3">
              <label class="form-label">Assign marks</label>
              <input class="form-control" type="number" min="0" max="<%= questionMarks %>" name="marks[<%= index %>]" value="<%= answer.marksObtained %>" required>
            </div>
          <% } %>

          <% if (isManualQuestion) { %>
            <div class="mb-3">
              <label class="form-label">Right answer / reference answer</label>
              <textarea class="form-control" name="teacherCorrectAnswers[<%= index %>]" rows="<%= questionType === 'coding' ? 6 : 3 %>" placeholder="<%= questionType === 'coding' ? 'Add the reference solution or expected approach' : 'Add the right answer for this written response' %>" <%= answer.needsManualReview ? 'required' : '' %>><%= referenceAnswer %></textarea>
            </div>
          <% } %>

          <div class="mb-3">
            <label class="form-label">Teacher comment</label>
            <textarea class="form-control" name="comments[<%= index %>]" rows="3" placeholder="Add feedback for the student" <%= answer.needsManualReview ? 'required' : '' %>><%= answer.reviewComment || '' %></textarea>
          </div>
        </div>
      <% }) %>
      <button class="btn btn-primary">Save Review</button>
    </form>
  </div>
</section>
