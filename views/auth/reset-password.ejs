<% layout('layouts/main') %>
<section class="auth-wrap">
  <div class="auth-card">
    <h1>Choose new password</h1>
    <form action="/auth/reset-password/<%= token %>" method="POST" class="vstack gap-3">
      <input class="form-control" type="password" name="password" placeholder="New password" minlength="6" required>
      <input class="form-control" type="password" name="confirmPassword" placeholder="Confirm new password" minlength="6" required>
      <button class="btn btn-primary" type="submit">Update Password</button>
    </form>
  </div>
</section>
