<% layout('layouts/main') %>

<section class="auth-screen">
  <div class="auth-stage animate-fade-in">
    <aside class="auth-showcase auth-showcase--accent">
      <div class="auth-showcase__content">
        <a href="/" class="auth-brand">
          <span class="auth-brand__mark">
            <i class="fa-brands fa-joomla"></i>
          </span>
          <span class="auth-brand__copy">
            <strong><%= appName %></strong>
            <small>Assessment made clearer</small>
          </span>
        </a>

        <div class="auth-showcase__intro">
          <span class="auth-kicker">Student signup</span>
          <h1>Create your space.</h1>
          <p>Set up a student account and start taking quizzes.</p>
        </div>

        <div class="auth-step-list" aria-hidden="true">
          <div class="auth-step">
            <span>1</span>
            <strong>Profile</strong>
          </div>
          <div class="auth-step">
            <span>2</span>
            <strong>Email</strong>
          </div>
          <div class="auth-step">
            <span>3</span>
            <strong>Password</strong>
          </div>
        </div>
      </div>

      <div class="auth-showcase__footer">
        <div class="auth-mini-strip">
          <span><i class="fas fa-user-graduate"></i> Student account</span>
          <span><i class="fas fa-user-shield"></i> Teacher by admin</span>
        </div>
      </div>
    </aside>

    <section class="auth-form-panel">
      <div class="auth-form-card">
        <a href="/" class="auth-brand auth-brand--mobile">
          <span class="auth-brand__mark">
            <i class="fa-brands fa-joomla"></i>
          </span>
          <span class="auth-brand__copy auth-brand__copy--dark">
            <strong><%= appName %></strong>
            <small>Assessment made clearer</small>
          </span>
        </a>

        <div class="auth-form-header">
          <h2>Create account</h2>
          <p>Student signup takes a minute.</p>
        </div>

        <form action="/auth/register" method="POST" class="auth-form-stack" x-data="{ showPassword: false, showConfirmPassword: false }">
          <label class="auth-field">
            <span>Full name</span>
            <input
              id="name"
              name="name"
              type="text"
              required
              class="form-input"
              placeholder="Enter your full name"
              value="<%= typeof name !== 'undefined' ? name : '' %>"
            >
          </label>

          <label class="auth-field">
            <span>Email address</span>
            <input
              id="email"
              name="email"
              type="email"
              required
              class="form-input"
              placeholder="Enter your email"
              value="<%= typeof email !== 'undefined' ? email : '' %>"
            >
          </label>

          <label class="auth-field">
            <span>Password</span>
            <div class="auth-input-wrap">
              <input
                id="password"
                name="password"
                :type="showPassword ? 'text' : 'password'"
                required
                minlength="6"
                class="form-input auth-input-pad"
                placeholder="Create a password"
              >
              <button
                type="button"
                @click="showPassword = !showPassword"
                class="auth-input-toggle"
                aria-label="Toggle password visibility"
              >
                <i :class="showPassword ? 'fas fa-eye-slash' : 'fas fa-eye'"></i>
              </button>
            </div>
            <small class="auth-field__hint">6+ characters.</small>
          </label>

          <label class="auth-field">
            <span>Confirm password</span>
            <div class="auth-input-wrap">
              <input
                id="confirmPassword"
                name="confirmPassword"
                :type="showConfirmPassword ? 'text' : 'password'"
                required
                minlength="6"
                class="form-input auth-input-pad"
                placeholder="Confirm your password"
              >
              <button
                type="button"
                @click="showConfirmPassword = !showConfirmPassword"
                class="auth-input-toggle"
                aria-label="Toggle password visibility"
              >
                <i :class="showConfirmPassword ? 'fas fa-eye-slash' : 'fas fa-eye'"></i>
              </button>
            </div>
          </label>

          <label for="terms" class="auth-check auth-check--start">
            <input
              id="terms"
              name="terms"
              type="checkbox"
              required
              class="form-check-input"
            >
            <span>
              I agree to the
              <a href="/terms" class="auth-subtle-link">Terms of Service</a>
              and
              <a href="/privacy" class="auth-subtle-link">Privacy Policy</a>
            </span>
          </label>

          <button type="submit" class="btn btn-primary auth-submit">
            <i class="fas fa-user-plus"></i>
            <span>Create Account</span>
          </button>
        </form>

        <p class="auth-alt-copy">
          Already have an account?
          <a href="/auth/login" class="auth-subtle-link">Sign in</a>
        </p>

      </div>
    </section>
  </div>
</section>
