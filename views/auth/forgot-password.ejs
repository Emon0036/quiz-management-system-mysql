<% layout('layouts/main') %>
<section class="auth-wrap">
  <div class="auth-card">
    <h1>Reset password</h1>
    <p class="text-muted">Enter your account email. The reset URL is printed in the server console and shown in development flash.</p>
    <form action="/auth/forgot-password" method="POST" class="vstack gap-3">
      <input class="form-control" type="email" name="email" placeholder="Email address" required>
      <button class="btn btn-primary" type="submit">Create Reset Link</button>
    </form>
  </div>
</section>
