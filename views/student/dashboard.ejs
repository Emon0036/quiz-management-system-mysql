<% layout('layouts/main') %>
<%
  const dashboardExamTypeCounts = {
    quiz: 0,
    'true-false': 0,
    'short-answer': 0,
    'coding-test': 0,
    ...(examTypeCounts || {})
  };
  const dashboardStats = {
    enrolledCount: 0,
    completedCount: 0,
    pendingReviewCount: 0,
    availableQuizCount: 0,
    ...(stats || {})
  };
  const dashboardProgress = {
    averageScore: 0,
    totalPoints: 0,
    streak: 0,
    totalQuizzes: 0,
    completedQuizzes: 0,
    inProgressQuizzes: 0,
    totalAttempts: 0,
    passedQuizzes: 0,
    failedQuizzes: 0,
    ...(progress || {})
  };
  const latestAttempt = recentAttempts && recentAttempts.length ? recentAttempts[0] : null;
  const latestAttemptScore = latestAttempt ? Number(latestAttempt.score || 0) : 0;
  const latestAttemptTotal = latestAttempt ? Number(latestAttempt.totalMarks || 0) : 0;
  const latestAttemptPercent = latestAttempt ? Number(latestAttempt.percentage || 0) : 0;
  const progressTotalQuizzes = Number(dashboardProgress.totalQuizzes || dashboardStats.enrolledCount || 0);
  const progressCompletedQuizzes = Number(dashboardProgress.completedQuizzes || 0);
  const progressInProgressQuizzes = Number(dashboardProgress.inProgressQuizzes || 0);
  const progressTotalAttempts = Number(dashboardProgress.totalAttempts || 0);
  const progressPassedQuizzes = Number(dashboardProgress.passedQuizzes || 0);
  const progressFailedQuizzes = Number(dashboardProgress.failedQuizzes || 0);
  const progressReviewedOutcomes = progressPassedQuizzes + progressFailedQuizzes;
  const dashboardCompletionRate = progressTotalQuizzes
    ? Math.max(0, Math.min(100, Math.round((progressCompletedQuizzes / progressTotalQuizzes) * 100)))
    : 0;
  const dashboardPassRate = progressReviewedOutcomes
    ? Math.max(0, Math.min(100, Math.round((progressPassedQuizzes / progressReviewedOutcomes) * 100)))
    : 0;
  const studentExamSegments = [
    {
      label: 'Quizzes',
      detail: 'Multiple choice and mixed exams',
      count: Number(dashboardExamTypeCounts.quiz || 0),
      color: '#0e5c8b'
    },
    {
      label: 'True/False',
      detail: 'Fast concept checks',
      count: Number(dashboardExamTypeCounts['true-false'] || 0),
      color: '#1c9b8f'
    },
    {
      label: 'Short Answer',
      detail: 'Teacher-reviewed responses',
      count: Number(dashboardExamTypeCounts['short-answer'] || 0),
      color: '#f59e0b'
    },
    {
      label: 'Coding Tests',
      detail: 'Hands-on programming exams',
      count: Number(dashboardExamTypeCounts['coding-test'] || 0),
      color: '#c2410c'
    }
  ];
  const totalExamMix = studentExamSegments.reduce((sum, segment) => sum + segment.count, 0);
  let studentChartFill = 'conic-gradient(rgba(67, 108, 140, 0.18) 0deg 360deg)';

  if (totalExamMix > 0) {
    let currentAngle = 0;
    studentChartFill = `conic-gradient(${studentExamSegments
      .filter((segment) => segment.count > 0)
      .map((segment) => {
        const startAngle = currentAngle;
        currentAngle += (segment.count / totalExamMix) * 360;
        return `${segment.color} ${startAngle}deg ${currentAngle}deg`;
      })
      .join(', ')})`;
  }

  const focusHref = dashboardStats.pendingReviewCount > 0
    ? '/student/reviews'
    : dashboardStats.enrolledCount > 0
      ? '/enrollments/my-quizzes'
      : '/enrollments/browse';
  const focusIcon = dashboardStats.pendingReviewCount > 0
    ? 'fa-comments'
    : dashboardStats.enrolledCount > 0
      ? 'fa-book-open'
      : 'fa-search';
  const focusTitle = dashboardStats.pendingReviewCount > 0
    ? 'Review feedback when it lands'
    : dashboardStats.enrolledCount > 0
      ? 'Continue your active exams'
      : 'Find your first exam';
  const focusCopy = dashboardStats.pendingReviewCount > 0
    ? `${dashboardStats.pendingReviewCount} submission${dashboardStats.pendingReviewCount === 1 ? '' : 's'} still waiting for teacher review.`
    : dashboardStats.enrolledCount > 0
      ? `${dashboardStats.enrolledCount} enrolled exam${dashboardStats.enrolledCount === 1 ? '' : 's'} in your workspace.`
      : 'Browse published exams and enroll when you are ready.';
%>

<section class="page-shell">
  <div class="page-container page-stack dashboard-layers">
    <section class="dashboard-hero dashboard-hero--compact animate-fade-in">
      <div class="dashboard-hero__grid dashboard-hero__grid--compact">
        <div class="dashboard-hero__content">
          <span class="eyebrow">Student Dashboard</span>
          <h1>Hi, <%= currentUser.name %>.</h1>
          <p>Your workspace is split into simple layers: today's focus, progress, exam lanes, and recent activity.</p>
          <div class="hero-action-row mt-4">
            <a href="/enrollments/browse" class="btn btn-primary">
              <i class="fas fa-search"></i>
              Browse exams
            </a>
            <a href="/enrollments/my-quizzes" class="btn btn-outline-primary">
              <i class="fas fa-book-open"></i>
              My exams
            </a>
          </div>
        </div>

        <aside class="dashboard-focus-card">
          <span class="dashboard-layer-label">Today</span>
          <div class="dashboard-focus-card__icon"><i class="fas <%= focusIcon %>"></i></div>
          <h2><%= focusTitle %></h2>
          <p><%= focusCopy %></p>
          <a href="<%= focusHref %>" class="btn btn-outline-primary btn-sm">Open focus</a>
        </aside>
      </div>
    </section>

    <section class="dashboard-layer">
      <div class="layer-header">
        <div>
          <span class="dashboard-layer-label">Layer 1</span>
          <h2>At a glance</h2>
        </div>
        <a href="/enrollments/progress" class="btn btn-outline-primary btn-sm">Full progress</a>
      </div>

      <div class="metric-grid dashboard-metric-grid">
        <article class="metric-card">
          <div class="metric-card__top">
            <div>
              <span class="metric-card__label">Enrolled</span>
              <strong class="metric-card__value"><%= dashboardStats.enrolledCount %></strong>
              <small class="metric-card__meta">Current exam workspace</small>
            </div>
            <span class="metric-card__icon"><i class="fas fa-layer-group"></i></span>
          </div>
        </article>
        <article class="metric-card">
          <div class="metric-card__top">
            <div>
              <span class="metric-card__label">Completed</span>
              <strong class="metric-card__value"><%= dashboardStats.completedCount %></strong>
              <small class="metric-card__meta">Submitted attempts</small>
            </div>
            <span class="metric-card__icon"><i class="fas fa-circle-check"></i></span>
          </div>
        </article>
        <article class="metric-card">
          <div class="metric-card__top">
            <div>
              <span class="metric-card__label">Pending Review</span>
              <strong class="metric-card__value"><%= dashboardStats.pendingReviewCount %></strong>
              <small class="metric-card__meta">Waiting for teacher marks</small>
            </div>
            <span class="metric-card__icon"><i class="fas fa-hourglass-half"></i></span>
          </div>
        </article>
        <article class="metric-card">
          <div class="metric-card__top">
            <div>
              <span class="metric-card__label">Average</span>
              <strong class="metric-card__value"><%= dashboardProgress.averageScore %>%</strong>
              <small class="metric-card__meta"><%= dashboardProgress.totalPoints %> total points</small>
            </div>
            <span class="metric-card__icon"><i class="fas fa-chart-line"></i></span>
          </div>
        </article>
      </div>
    </section>

    <section class="dashboard-layer dashboard-layer-grid">
      <article class="chart-card">
        <div class="panel-header">
          <div class="panel-header__copy">
            <span class="dashboard-layer-label">Layer 2</span>
            <h2>Progress snapshot</h2>
            <p>Your exam mix and learning totals without the extra noise.</p>
          </div>
        </div>

        <div class="chart-card__body">
          <div class="donut-chart" style="--chart-fill: <%= studentChartFill %>;">
            <div class="donut-chart__center">
              <strong class="donut-chart__value"><%= totalExamMix %></strong>
              <span class="donut-chart__label">Tracked exams</span>
            </div>
          </div>

          <div class="chart-legend">
            <% studentExamSegments.forEach((segment) => { %>
              <div class="legend-item">
                <span class="legend-dot" style="background: <%= segment.color %>;"></span>
                <div class="legend-copy">
                  <strong><%= segment.label %></strong>
                  <span><%= segment.detail %></span>
                </div>
                <span class="legend-value"><%= segment.count %></span>
              </div>
            <% }) %>
          </div>
        </div>
      </article>

      <aside class="dashboard-side-stack">
        <div class="compact-stat-grid compact-stat-grid--stacked">
          <article class="compact-stat">
            <span>Completion</span>
            <strong><%= dashboardCompletionRate %>%</strong>
            <small><%= progressCompletedQuizzes %> of <%= progressTotalQuizzes %> finalized</small>
          </article>
          <article class="compact-stat">
            <span>Pass Rate</span>
            <strong><%= dashboardPassRate %>%</strong>
            <small><%= progressPassedQuizzes %> pass / <%= progressFailedQuizzes %> fail</small>
          </article>
          <article class="compact-stat">
            <span>Streak</span>
            <strong><%= dashboardProgress.streak %></strong>
            <small>Learning activity streak</small>
          </article>
        </div>

        <div class="support-card">
          <span class="dashboard-layer-label">Shortcuts</span>
          <div class="support-list">
            <a href="/enrollments/browse"><i class="fas fa-search"></i><span>Browse and enroll</span></a>
            <a href="/enrollments/my-quizzes"><i class="fas fa-book-open"></i><span>Continue exams</span></a>
            <a href="/student/reviews"><i class="fas fa-comments"></i><span>Review center</span></a>
            <a href="/student/history"><i class="fas fa-clock-rotate-left"></i><span>Attempt history</span></a>
          </div>
        </div>
      </aside>
    </section>

    <section class="dashboard-layer">
      <div class="layer-header">
        <div>
          <span class="dashboard-layer-label">Layer 3</span>
          <h2>Exam lanes</h2>
        </div>
      </div>

      <div class="action-grid action-grid--compact">
        <a href="/enrollments/my-quizzes?type=quiz" class="action-card">
          <div class="action-card__top">
            <div>
              <span class="status-pill approved">Quiz</span>
              <h3 class="mt-3">Multiple Choice</h3>
              <p>Standard quiz questions.</p>
            </div>
            <span class="action-card__count"><%= dashboardExamTypeCounts.quiz %></span>
          </div>
          <span class="action-card__footer">Open lane <i class="fas fa-arrow-right"></i></span>
        </a>

        <a href="/enrollments/my-quizzes?type=true-false" class="action-card">
          <div class="action-card__top">
            <div>
              <span class="status-pill approved">True/False</span>
              <h3 class="mt-3">Concept Checks</h3>
              <p>Fast assessments.</p>
            </div>
            <span class="action-card__count"><%= dashboardExamTypeCounts['true-false'] %></span>
          </div>
          <span class="action-card__footer">Open lane <i class="fas fa-arrow-right"></i></span>
        </a>

        <a href="/enrollments/my-quizzes?type=short-answer" class="action-card">
          <div class="action-card__top">
            <div>
              <span class="status-pill pending">Short Answer</span>
              <h3 class="mt-3">Teacher Review</h3>
              <p>Written responses.</p>
            </div>
            <span class="action-card__count"><%= dashboardExamTypeCounts['short-answer'] %></span>
          </div>
          <span class="action-card__footer">Open lane <i class="fas fa-arrow-right"></i></span>
        </a>

        <a href="/enrollments/my-quizzes?type=coding-test" class="action-card">
          <div class="action-card__top">
            <div>
              <span class="status-pill approved">Coding</span>
              <h3 class="mt-3">Coding Tests</h3>
              <p>Practical programming.</p>
            </div>
            <span class="action-card__count"><%= dashboardExamTypeCounts['coding-test'] %></span>
          </div>
          <span class="action-card__footer">Open lane <i class="fas fa-arrow-right"></i></span>
        </a>
      </div>
    </section>

    <section class="dashboard-layer">
      <div class="layer-header">
        <div>
          <span class="dashboard-layer-label">Layer 4</span>
          <h2>Recent attempts</h2>
        </div>
        <a href="/student/history" class="btn btn-outline-primary btn-sm">View history</a>
      </div>

      <% if (recentAttempts && recentAttempts.length > 0) { %>
        <div class="activity-list activity-list--split">
          <% recentAttempts.slice(0, 5).forEach((attempt) => { %>
            <% const attemptQuiz = attempt.quiz || {}; %>
            <% const attemptDate = attempt.submittedAt || attempt.createdAt; %>
            <article class="activity-item">
              <div class="activity-item__main">
                <span class="activity-item__icon"><i class="fas fa-file-signature"></i></span>
                <div>
                  <p class="activity-item__title"><%= attemptQuiz.title || 'Removed quiz' %></p>
                  <p class="activity-item__meta">
                    <%= attemptQuiz.category || 'General' %> &middot;
                    <%= attemptDate ? new Date(attemptDate).toLocaleDateString() : 'No date available' %>
                  </p>
                </div>
              </div>
              <div class="activity-score">
                <strong><%= attempt.percentage %>%</strong>
                <span><%= attempt.status === 'pending-review' ? 'Pending review' : 'Recorded score' %></span>
              </div>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <h3>No recent attempts yet</h3>
          <p>Start with an available exam and your latest activity will appear here.</p>
          <a href="/enrollments/browse" class="btn btn-primary mt-3">Browse exams</a>
        </div>
      <% } %>
    </section>

    <details class="dashboard-drawer">
      <summary>
        <div>
          <span class="dashboard-layer-label">Optional details</span>
          <h2>How scoring works</h2>
          <p>Open this only when you need the full calculation rules.</p>
        </div>
        <i class="fas fa-chevron-down"></i>
      </summary>

      <div class="dashboard-drawer__body">
        <div class="calculation-snapshot">
          <article>
            <span>Latest attempt</span>
            <strong>
              <% if (latestAttempt) { %>
                <%= latestAttemptScore %>/<%= latestAttemptTotal %> = <%= latestAttemptPercent %>%
              <% } else { %>
                No attempt yet
              <% } %>
            </strong>
            <small>Marks earned divided by total marks.</small>
          </article>
          <article>
            <span>Finalized</span>
            <strong><%= progressTotalAttempts %></strong>
            <small>Used for average, points, streak, and rank.</small>
          </article>
          <article>
            <span>Pending review</span>
            <strong><%= dashboardStats.pendingReviewCount %></strong>
            <small>Manual answers update after teacher marking.</small>
          </article>
          <article>
            <span>In progress</span>
            <strong><%= progressInProgressQuizzes %></strong>
            <small>Enrolled exams not finalized yet.</small>
          </article>
        </div>

        <div class="formula-grid">
          <article class="formula-card">
            <i class="fas fa-percent"></i>
            <h3>Percentage</h3>
            <p>Percentage is rounded from marks earned divided by total marks.</p>
            <strong>Latest: <%= latestAttempt ? `${latestAttemptPercent}%` : 'None' %></strong>
          </article>
          <article class="formula-card">
            <i class="fas fa-star"></i>
            <h3>Points</h3>
            <p>Easy x1, Medium x1.25, and Hard x1.5 are applied to your percentage.</p>
            <strong>Current: <%= dashboardProgress.totalPoints %></strong>
          </article>
          <article class="formula-card">
            <i class="fas fa-medal"></i>
            <h3>Grades</h3>
            <p>A is 90%+, B is 80%+, C is 70%+, D is 60%+, and F is below 60%.</p>
            <strong>Pass rate: <%= dashboardPassRate %>%</strong>
          </article>
        </div>
      </div>
    </details>
  </div>
</section>
