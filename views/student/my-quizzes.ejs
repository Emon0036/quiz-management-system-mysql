<% layout('layouts/main') %>
<section class="page-shell">
  <div class="page-container page-stack">
    <% const examTypeLabels = { quiz: 'Quiz', 'true-false': 'True/False', 'short-answer': 'Short Question', 'coding-test': 'Coding Exam' }; %>
    <% const categorySections = categoryGroups || []; %>
    <% const currentType = selectedType || 'all'; %>
    <% const currentCategory = selectedCategory || 'all'; %>
    <% const totalCount = categorySections.reduce((sum, group) => sum + (group.enrollments?.length || 0), 0); %>
    <% const codingProblemCount = (codingProblems || []).length; %>
    <% const buildTypeLink = (typeValue) => `/enrollments/my-quizzes?type=${encodeURIComponent(typeValue)}&category=${encodeURIComponent(currentCategory)}`; %>
    <% const buildCategoryLink = (categoryValue) => `/enrollments/my-quizzes?type=${encodeURIComponent(currentType)}&category=${encodeURIComponent(categoryValue)}`; %>

    <div class="page-heading">
      <div>
        <span class="eyebrow">Student</span>
        <h1>My Exams</h1>
        <p>Your enrolled exams are grouped by category so each subject stays easier to scan before you start an attempt.</p>
      </div>
      <div class="toolbar">
        <a href="/enrollments/browse" class="btn btn-outline-primary">Browse Exams</a>
        <a href="/enrollments/progress" class="btn btn-primary">Progress</a>
      </div>
    </div>

    <div class="chip-group">
      <a class="filter-chip <%= (selectedType || 'all') === 'all' ? 'is-active' : '' %>" href="<%= buildTypeLink('all') %>">All</a>
      <a class="filter-chip <%= selectedType === 'quiz' ? 'is-active' : '' %>" href="<%= buildTypeLink('quiz') %>">Quiz</a>
      <a class="filter-chip <%= selectedType === 'true-false' ? 'is-active' : '' %>" href="<%= buildTypeLink('true-false') %>">True/False</a>
      <a class="filter-chip <%= selectedType === 'short-answer' ? 'is-active' : '' %>" href="<%= buildTypeLink('short-answer') %>">Short Question</a>
      <a class="filter-chip <%= selectedType === 'coding-test' ? 'is-active' : '' %>" href="<%= buildTypeLink('coding-test') %>">Coding Exam</a>
    </div>

    <% if ((enrollmentCategories || []).length > 0) { %>
      <div class="chip-group">
        <a class="filter-chip <%= (selectedCategory || 'all') === 'all' ? 'is-active' : '' %>" href="<%= buildCategoryLink('all') %>">All categories</a>
        <% enrollmentCategories.forEach((category) => { %>
          <a class="filter-chip <%= selectedCategory === category ? 'is-active' : '' %>" href="<%= buildCategoryLink(category) %>"><%= category %></a>
        <% }) %>
      </div>
    <% } %>

    <% if (!totalCount && !codingProblemCount) { %>
      <div class="empty-state">
        <h3>You have not enrolled anywhere yet</h3>
        <p>Browse the published exam catalog to build your personal workspace.</p>
        <a href="/enrollments/browse" class="btn btn-primary mt-3">Browse exams</a>
      </div>
    <% } %>

    <% categorySections.forEach((group) => { %>
      <section class="table-card table-shell">
        <div class="panel-header">
          <div class="panel-header__copy">
            <span class="eyebrow">Category</span>
            <h2><%= group.category %></h2>
            <p><%= group.enrollments.length %> enrolled exam<%= group.enrollments.length === 1 ? '' : 's' %> in this subject.</p>
          </div>
          <span class="status-pill approved"><%= group.enrollments.length %> enrolled</span>
        </div>

        <div class="table-responsive">
          <table class="table align-middle">
            <thead>
              <tr>
                <th>Exam</th>
                <th>Type</th>
                <th>Status</th>
                <th>Best %</th>
                <th class="text-end">Action</th>
              </tr>
            </thead>
            <tbody>
              <% group.enrollments.forEach((enrollment) => { %>
                <tr>
                  <td>
                    <div class="quiz-table-title">
                      <% if (enrollment.quiz.thumbnailUrl) { %>
                        <img src="<%= enrollment.quiz.thumbnailUrl %>" alt="<%= enrollment.quiz.title %> thumbnail" loading="lazy">
                      <% } else { %>
                        <span class="quiz-table-title__placeholder"><i class="fas fa-image"></i></span>
                      <% } %>
                      <div>
                        <strong><%= enrollment.quiz.title %></strong>
                        <div class="small text-muted">
                          <%= enrollment.quiz.duration %> min · <%= enrollment.quiz.totalMarks %> marks · Pass <%= enrollment.quiz.passingMarks %>% · <%= enrollment.quiz.createdBy?.name || 'Teacher' %>
                        </div>
                      </div>
                    </div>
                  </td>
                  <td><span class="badge text-bg-secondary"><%= examTypeLabels[enrollment.quiz.examType || 'quiz'] %></span></td>
                  <td>
                    <% if (enrollment.status === 'completed') { %>
                      <span class="badge text-bg-success">Completed</span>
                    <% } else if (enrollment.status === 'pending-review') { %>
                      <span class="badge text-bg-warning">Pending Review</span>
                    <% } else { %>
                      <span class="badge text-bg-primary">Enrolled</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (enrollment.status === 'completed') { %>
                      <%= enrollment.bestScore %>%
                    <% } else if (enrollment.status === 'pending-review') { %>
                      <span class="text-muted">Pending</span>
                    <% } else { %>
                      <span class="text-muted">-</span>
                    <% } %>
                  </td>
                  <td class="text-end">
                    <div class="action-stack">
                      <a class="btn btn-sm btn-primary" href="/student/quizzes/<%= enrollment.quiz._id %>/take">
                        <%= enrollment.attempts ? 'Attempt Again' : 'Attempt' %>
                      </a>
                      <% if (enrollment.bestAttemptId) { %>
                        <a class="btn btn-sm btn-outline-secondary" href="/student/results/<%= enrollment.bestAttemptId._id || enrollment.bestAttemptId %>">View Result</a>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    <% }) %>

    <% if ((selectedType === 'all' || selectedType === 'coding-test') && (selectedCategory || 'all') === 'all' && codingProblemCount) { %>
      <section class="table-card table-shell">
        <div class="panel-header">
          <div class="panel-header__copy">
            <span class="eyebrow">Coding Practice</span>
            <h2>Hands-on coding problems</h2>
            <p>Standalone challenges you can solve outside the exam flow.</p>
          </div>
          <a href="/problems" class="btn btn-outline-primary btn-sm">Open challenge library</a>
        </div>

        <div class="table-responsive">
          <table class="table align-middle">
            <thead>
              <tr>
                <th>Problem</th>
                <th>Difficulty</th>
                <th>Latest Submission</th>
                <th>Status</th>
                <th class="text-end">Action</th>
              </tr>
            </thead>
            <tbody>
              <% codingProblems.forEach((item) => { %>
                <tr>
                  <td>
                    <strong><%= item.problem.title %></strong>
                    <div class="small text-muted">Practice challenge</div>
                  </td>
                  <td><%= item.problem.difficulty || 'Unspecified' %></td>
                  <td>
                    <% if (item.latestSubmission) { %>
                      <%= new Date(item.latestSubmission.submittedAt).toLocaleDateString() %>
                    <% } else { %>
                      <span class="text-muted">Not attempted</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (!item.latestSubmission) { %>
                      <span class="badge text-bg-primary">Ready</span>
                    <% } else if (item.latestSubmission.status === 'reviewed') { %>
                      <span class="badge text-bg-success">Reviewed</span>
                    <% } else { %>
                      <span class="badge text-bg-warning">Pending Review</span>
                    <% } %>
                  </td>
                  <td class="text-end">
                    <div class="action-stack">
                      <a class="btn btn-sm btn-primary" href="/problems/<%= item.problem._id %>">Solve</a>
                      <% if (item.latestSubmission) { %>
                        <a class="btn btn-sm btn-outline-secondary" href="/submissions/<%= item.latestSubmission._id %>/view">Latest Submission</a>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    <% } %>
  </div>
</section>
