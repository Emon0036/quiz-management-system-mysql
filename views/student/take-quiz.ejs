<% layout('layouts/main') %>
<%
  const displayedAttemptNumber = typeof currentAttemptNumber !== 'undefined' ? currentAttemptNumber : 1;
  const displayedAttemptLimit = typeof attemptLimit !== 'undefined' ? attemptLimit : (quiz.maxAttempts || 10);
%>
<section class="page-shell">
  <div class="page-container page-stack">
    <div class="quiz-header">
      <div>
        <span class="eyebrow"><%= quiz.category %></span>
        <h1><%= quiz.title %></h1>
        <p><%= quiz.questions.length %> question<%= quiz.questions.length === 1 ? '' : 's' %> &middot; <%= quiz.totalMarks %> marks total &middot; Attempt <%= displayedAttemptNumber %> of <%= displayedAttemptLimit %></p>
      </div>
      <% if (quiz.thumbnailUrl) { %>
        <img class="quiz-header__thumbnail" src="<%= quiz.thumbnailUrl %>" alt="<%= quiz.title %> thumbnail">
      <% } %>
      <div class="timer" data-duration="<%= quiz.duration %>">
        <i class="fa-regular fa-clock"></i>
        <span id="timerText"><%= quiz.duration %>:00</span>
      </div>
    </div>

    <section class="exam-security-note" aria-labelledby="examSecurityTitle" aria-live="polite">
      <div class="exam-security-note__icon" aria-hidden="true">
        <i class="fa-solid fa-shield-halved"></i>
      </div>
      <div class="exam-security-note__content">
        <div class="exam-security-note__header">
          <div>
            <span class="exam-security-note__label">Exam security rules</span>
            <h2 id="examSecurityTitle">Three safety chances before auto-submit</h2>
          </div>
          <div class="exam-security-note__status">
            <span id="securityTrialsText">3 chances left</span>
            <span id="securityRecoveryText" class="d-none">Return window: 0:15</span>
          </div>
        </div>
        <p>
          During the exam, copying, cutting, pasting, copy/paste shortcuts, developer tools attempts,
          right-click actions, leaving this tab, or switching to another window are treated as security
          incidents. The first 3 incidents are warnings so an accidental action does not immediately end
          the exam. Any incident after those 3 warnings will auto-submit the exam.
        </p>
        <p class="mb-0">
          If you leave the exam tab or window, a 15 second return window starts immediately. Come back to
          this exam within that window to continue. If the 15 second limit is crossed, the exam is
          auto-submitted even if you still have warning chances left.
        </p>
        <p id="securityWarningText" class="exam-security-note__live d-none"></p>
      </div>
    </section>

    <form id="quizForm" action="/student/quizzes/<%= quiz._id %>/submit" method="POST" class="form-panel">
    <input type="hidden" name="timeSpent" id="timeSpent" value="0">
    <input type="hidden" name="autoSubmitted" id="autoSubmitted" value="0">
    <input type="hidden" name="autoSubmitReason" id="autoSubmitReason" value="">
    <% if (typeof rosterAccess !== 'undefined' && rosterAccess) { %>
      <input type="hidden" name="examRosterStudentId" value="<%= rosterAccess.studentId %>">
      <input type="hidden" name="examRosterSection" value="<%= rosterAccess.section || '' %>">
      <div class="alert alert-info small">
        <i class="fa-solid fa-id-card me-2"></i>
        Verified student: <strong><%= rosterAccess.studentName || rosterAccess.studentId %></strong>
        <% if (rosterAccess.studentName) { %>
          <span>(ID: <%= rosterAccess.studentId %>)</span>
        <% } %>
        <% if (rosterAccess.section) { %>
          <span class="d-block">Section: <strong><%= rosterAccess.section %></strong></span>
        <% } %>
      </div>
    <% } %>
    
    <% quiz.questions.forEach((question, index) => { %>
      <article class="question-card">
        <div class="question-card__top">
          <div class="question-card__meta">
            <span class="question-index"><%= index + 1 %></span>
            <h2 class="question-card__title"><%= question.questionText %></h2>
          </div>
          <span class="status-pill approved"><%= question.marks %> mark<%= question.marks === 1 ? '' : 's' %></span>
        </div>
        
        <% if (question.type === 'coding') { %>
          <%
            const codingLanguage = question.language || 'Any programming language';
            const normalizedLanguage = String(codingLanguage).toLowerCase();
            const fileExtension = normalizedLanguage.includes('javascript') ? 'js'
              : normalizedLanguage.includes('python') ? 'py'
              : normalizedLanguage.includes('java') ? 'java'
              : normalizedLanguage.includes('c++') || normalizedLanguage.includes('cpp') ? 'cpp'
              : normalizedLanguage === 'c' || normalizedLanguage.includes(' c ') ? 'c'
              : normalizedLanguage.includes('php') ? 'php'
              : normalizedLanguage.includes('ruby') ? 'rb'
              : normalizedLanguage.includes('go') ? 'go'
              : normalizedLanguage.includes('sql') ? 'sql'
              : 'code';
          %>
          <div class="coding-panel mb-3">
            <% if (question.codeTemplate && question.codeTemplate.trim()) { %>
              <div class="alert alert-info small mb-3">
                <strong>Template:</strong><br>
                <pre><%= question.codeTemplate %></pre>
              </div>
            <% } %>
            
            <% if (question.testCases && question.testCases.length > 0) { %>
              <div class="alert alert-info small mb-3">
                <strong>Sample Cases:</strong>
                <% question.testCases.forEach((testCase, tcIndex) => { %>
                  <div class="mt-2">
                    <strong>Sample <%= tcIndex + 1 %>:</strong><br>
                    <strong>Input:</strong>
                    <pre class="code-block mt-1 mb-2"><code><%= testCase.input %></code></pre>
                    <strong>Output:</strong>
                    <pre class="code-block mt-1 mb-0"><code><%= testCase.expectedOutput %></code></pre>
                  </div>
                <% }) %>
              </div>
            <% } %>

            <div class="code-ide" data-code-ide>
              <div class="code-ide__titlebar">
                <div class="code-ide__window-controls" aria-hidden="true">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
                <div class="code-ide__tabs">
                  <span class="code-ide__tab is-active">
                    <i class="fa-solid fa-code"></i>
                    solution.<%= fileExtension %>
                  </span>
                </div>
                <div class="code-ide__meta">
                  <span><i class="fa-solid fa-circle"></i> Ready</span>
                </div>
              </div>
              <div class="code-ide__crumbs">
                <span>Language</span>
                <strong><%= codingLanguage %></strong>
                <span class="code-ide__divider" aria-hidden="true"></span>
                <span data-code-lines>1 line</span>
              </div>
              <div class="code-ide__editor">
                <pre class="code-ide__gutter" data-code-gutter aria-hidden="true">1</pre>
                <label class="visually-hidden" for="codeEditor-<%= question._id %>">Code answer for question <%= index + 1 %></label>
                <textarea
                  id="codeEditor-<%= question._id %>"
                  class="form-control code-editor"
                  name="code[<%= question._id %>]"
                  data-language="<%= codingLanguage %>"
                  data-code-editor
                  rows="14"
                  placeholder="// Write your code here..."
                  spellcheck="false"
                  autocomplete="off"
                  autocapitalize="off"
                  autocorrect="off"
                  wrap="off"
                  required><%= question.codeTemplate || '' %></textarea>
              </div>
              <div class="code-ide__statusbar">
                <span><i class="fa-solid fa-keyboard"></i> Insert</span>
                <span data-code-cursor>Ln 1, Col 1</span>
                <span><%= codingLanguage %></span>
              </div>
            </div>
          </div>
        <% } else if (question.type === 'short-answer') { %>
          <textarea class="form-control" name="answers[<%= question._id %>]" rows="3" placeholder="Write your answer" required></textarea>
        <% } else { %>
          <% question.options.forEach((option) => { %>
            <label class="answer-option">
              <input type="radio" name="answers[<%= question._id %>]" value="<%= option %>" required>
              <span><%= option %></span>
            </label>
          <% }) %>
        <% } %>
      </article>
    <% }) %>
    
    <button class="btn btn-primary btn-lg" type="submit">Submit <%= quiz.examType === 'coding-test' ? 'Exam' : 'Quiz' %></button>
    </form>
  </div>
</section>

<script src="/js/quizTimer.js"></script>
